---
import '@/styles/global.css';
import Portal from '@/components/Portal';
import { SITE_CONFIG } from '@/config/site';
import Favicon from '@/components/Favicon.astro';

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<html lang="en" data-theme-palette={SITE_CONFIG.branding.darkModePalette}>
	<head>
		<meta charset="utf-8" />
		<Favicon />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary SEO Meta Tags -->
		<title>{SITE_CONFIG.seo.title}</title>
		<meta name="title" content={SITE_CONFIG.seo.title} />
		<meta name="description" content={SITE_CONFIG.seo.description} />
		<meta name="keywords" content={SITE_CONFIG.seo.keywords.join(', ')} />
		<meta name="author" content={SITE_CONFIG.branding.creator} />
		
		<!-- Open Graph / Facebook / WhatsApp -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={SITE_CONFIG.seo.url} />
		<meta property="og:title" content={SITE_CONFIG.seo.title} />
		<meta property="og:description" content={SITE_CONFIG.seo.description} />
		<meta property="og:image" content={SITE_CONFIG.seo.ogImage} />
		<meta property="og:site_name" content={SITE_CONFIG.branding.name} />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={SITE_CONFIG.seo.url} />
		<meta property="twitter:title" content={SITE_CONFIG.seo.title} />
		<meta property="twitter:description" content={SITE_CONFIG.seo.description} />
		<meta property="twitter:image" content={SITE_CONFIG.seo.ogImage} />
		<meta property="twitter:site" content={SITE_CONFIG.seo.twitterHandle} />
		<meta property="twitter:creator" content={SITE_CONFIG.seo.twitterHandle} />
		<!-- Block-level Initializer Script to prevent theme & route flickering -->
		<script is:inline>
			(function() {
				// Theme setup
				const savedTheme = localStorage.getItem("theme");
				const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
				const useDark = savedTheme === "dark" || (!savedTheme && systemDark);
				if (useDark) {
					document.documentElement.classList.add("dark");
				} else {
					document.documentElement.classList.remove("dark");
				}

				// Route parameter loading setup to prevent flash of incorrect route layout
				const params = new URLSearchParams(window.location.search);
				if (params.get("category") || params.get("template") || params.get("editor")) {
					document.documentElement.classList.add("route-loading");
				}
			})();
		</script>

		<!-- Dynamic theme-color bar matching CapCut dark grey and light mode gray -->
		<meta name="theme-color" content="#f9fafb" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#111111" media="(prefers-color-scheme: dark)" />

		<!-- PWA Service Worker Registration -->
		<script is:inline define:vars={{ base }}>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					const swUrl = `${base}/sw.js`;
					navigator.serviceWorker.register(swUrl)
						.then((reg) => console.log('[PWA] Service Worker registered successfully, scope:', reg.scope))
						.catch((err) => console.error('[PWA] Service Worker registration failed:', err));
				});
			}
		</script>

		<!-- Google Fonts Outfit & Inter -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<Portal client:load />
	</body>
</html>
