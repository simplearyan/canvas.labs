---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../config/site';

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout title="Press & Media Resources" description="Access official media resources, press kits, and promotional web video editors for CanvasLabs.">
	<!-- Back link -->
	<a href={base + "/"} class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-brand-500 transition-colors group mb-4">
		<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
		Back to Hub
	</a>

	<!-- Premium Responsive Grid/Container -->
	<div class="max-w-4xl w-full mx-auto space-y-12 py-4">
		<!-- Header -->
		<div class="text-center space-y-3">
			<h1 class="text-4xl font-extrabold tracking-tight text-text-main font-sans">Press & Media Kit</h1>
			<p class="text-sm text-text-muted max-w-lg mx-auto leading-relaxed">
				Official media resources, design concept links, and responsive promotional editor portals for reviewers, creators, and journalists.
			</p>
		</div>

		<!-- Section 1: Promotional Editors (Central Focus) -->
		<div class="space-y-6">
			<div class="flex items-center gap-3 border-b border-border-color/30 pb-3">
				<div class="w-2.5 h-6 bg-brand-500 rounded-full"></div>
				<h2 class="text-xl font-bold text-text-main">Interactive Promotional Editors</h2>
			</div>

			<div class="grid md:grid-cols-2 gap-6">
				<!-- Kenichi V1 Studio Portal -->
				<div class="relative bg-card-bg border border-border-color/40 rounded-3xl p-6 shadow-sm overflow-hidden group flex flex-col justify-between transition-all hover:-translate-y-1 hover:shadow-md">
					<div class="absolute -top-12 -right-12 w-40 h-40 bg-brand-500/5 rounded-full blur-3xl group-hover:bg-brand-500/10 transition-all duration-500"></div>
					
					<div class="space-y-4">
						<div class="flex items-center justify-between">
							<div class="w-10 h-10 rounded-xl bg-gray-900 dark:bg-white flex items-center justify-center text-white dark:text-black font-black text-lg">K</div>
							<span class="text-[10px] bg-brand-500/10 text-brand-500 font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">Editor V1</span>
						</div>
						
						<div class="space-y-2">
							<h3 class="text-lg font-bold text-text-main group-hover:text-brand-500 transition-colors">Kenichi Studio (Standard Edition)</h3>
							<p class="text-xs text-text-muted leading-relaxed">
								The classic high-fidelity dark-mode landing page designed to mimic premium desktop video editor timelines, panel navigators, and interactive waveforms.
							</p>
						</div>
					</div>

					<div class="pt-6">
						<a 
							href={base + "/kenichi"} 
							class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-black/5 dark:bg-white/5 hover:bg-brand-500 hover:text-white dark:hover:bg-brand-500 dark:hover:text-white border border-border-color text-text-main rounded-xl text-xs font-bold transition-all outline-none"
						>
							Launch V1 Editor Demo
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
						</a>
					</div>
				</div>

				<!-- Kenichi V2 Matte Edition -->
				<div class="relative bg-card-bg border border-border-color/40 rounded-3xl p-6 shadow-sm overflow-hidden group flex flex-col justify-between transition-all hover:-translate-y-1 hover:shadow-md">
					<div class="absolute -top-12 -right-12 w-40 h-40 bg-brand-500/5 rounded-full blur-3xl group-hover:bg-brand-500/10 transition-all duration-500"></div>
					
					<div class="space-y-4">
						<div class="flex items-center justify-between">
							<div class="w-10 h-10 rounded-xl bg-brand-500 flex items-center justify-center text-white font-black text-lg">K2</div>
							<span class="text-[10px] bg-green-500/10 text-green-500 font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">Editor V2</span>
						</div>
						
						<div class="space-y-2">
							<h3 class="text-lg font-bold text-text-main group-hover:text-brand-500 transition-colors">Kenichi Matte Pro (CapCut Colorway)</h3>
							<p class="text-xs text-text-muted leading-relaxed">
								Premium matte charcoal theme matching authentic CapCut editor specs. Includes interactive AI background remover slider and playhead timelines.
							</p>
						</div>
					</div>

					<div class="pt-6">
						<a 
							href={base + "/kenichi-v2"} 
							class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-brand-500/10 text-brand-500 hover:bg-brand-500 hover:text-white rounded-xl text-xs font-bold transition-all outline-none"
						>
							Launch V2 Matte Demo
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
						</a>
					</div>
				</div>

				<!-- Logo Customizer Pro Tool -->
				<div class="relative bg-card-bg border border-border-color/40 rounded-3xl p-6 shadow-sm overflow-hidden group flex flex-col justify-between transition-all hover:-translate-y-1 hover:shadow-md">
					<div class="absolute -top-12 -right-12 w-40 h-40 bg-brand-500/5 rounded-full blur-3xl group-hover:bg-brand-500/10 transition-all duration-500"></div>
					
					<div class="space-y-4">
						<div class="flex items-center justify-between">
							<div class="w-10 h-10 rounded-xl bg-brand-600 flex items-center justify-center text-white font-black text-lg">LC</div>
							<span class="text-[10px] bg-brand-500/10 text-brand-500 font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">Design Tool</span>
						</div>
						
						<div class="space-y-2">
							<h3 class="text-lg font-bold text-text-main group-hover:text-brand-500 transition-colors">Pro Logo Customizer (v3 Studio)</h3>
							<p class="text-xs text-text-muted leading-relaxed">
								A fully client-side interactive branding tool enabling real-time font adjustments, custom drop shadows, radial gradient backgrounds, and transparent 4K/Vector SVG exports.
							</p>
						</div>
					</div>

					<div class="pt-6">
						<a 
							href={base + "/tool/logo-customizer-v3"} 
							class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-brand-600 text-white hover:bg-brand-700 rounded-xl text-xs font-bold transition-all outline-none"
						>
							Launch Customizer Studio
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
						</a>
					</div>
				</div>

				<!-- Favicon & Browser Tab Studio -->
				<div class="relative bg-card-bg border border-border-color/40 rounded-3xl p-6 shadow-sm overflow-hidden group flex flex-col justify-between transition-all hover:-translate-y-1 hover:shadow-md">
					<div class="absolute -top-12 -right-12 w-40 h-40 bg-brand-500/5 rounded-full blur-3xl group-hover:bg-brand-500/10 transition-all duration-500"></div>
					
					<div class="space-y-4">
						<div class="flex items-center justify-between">
							<div class="w-10 h-10 rounded-xl bg-brand-500 flex items-center justify-center text-white font-black text-lg">FG</div>
							<span class="text-[10px] bg-brand-500/10 text-brand-500 font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">Design Tool</span>
						</div>
						
						<div class="space-y-2">
							<h3 class="text-lg font-bold text-text-main group-hover:text-brand-500 transition-colors">Favicon & Browser Tab Studio</h3>
							<p class="text-xs text-text-muted leading-relaxed">
								A comprehensive favicon designer enabling text monograms, multi-resolution PNG/SVG vector kit creation, and premium real-time Chrome white/dark tab mockups.
							</p>
						</div>
					</div>

					<div class="pt-6">
						<a 
							href={base + "/tool/favicon-generator"} 
							class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-brand-500 text-white hover:bg-brand-600 rounded-xl text-xs font-bold transition-all outline-none"
						>
							Launch Favicon Studio
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
						</a>
					</div>
				</div>

				<!-- CapCut Dark Favicon Studio -->
				<div class="relative bg-card-bg border border-border-color/40 rounded-3xl p-6 shadow-sm overflow-hidden group flex flex-col justify-between transition-all hover:-translate-y-1 hover:shadow-md">
					<div class="absolute -top-12 -right-12 w-40 h-40 bg-brand-500/5 rounded-full blur-3xl group-hover:bg-brand-500/10 transition-all duration-500"></div>
					
					<div class="space-y-4">
						<div class="flex items-center justify-between">
							<div class="w-10 h-10 rounded-xl bg-zinc-950 border border-zinc-800 flex items-center justify-center text-white font-black text-lg">CS</div>
							<span class="text-[10px] bg-cyan-500/10 text-cyan-400 font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">CapCut Dark</span>
						</div>
						
						<div class="space-y-2">
							<h3 class="text-lg font-bold text-text-main group-hover:text-brand-500 transition-colors">CapCut Dark Favicon Studio</h3>
							<p class="text-xs text-text-muted leading-relaxed">
								An ultra-clean, minimal dashboard designed under authentic CapCut studio specs. Features drag-and-drop SVGs, side-by-side light/dark tab previews, and animated mobile app splash testing.
							</p>
						</div>
					</div>

					<div class="pt-6">
						<a 
							href={base + "/tool/favicon-studio"} 
							class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-500 hover:to-brand-600 text-white rounded-xl text-xs font-bold transition-all outline-none"
						>
							Launch CapCut Studio
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
						</a>
					</div>
				</div>
			</div>
		</div>

		<!-- Section 2: Logo and Visual Kit -->
		<div class="space-y-6">
			<div class="flex items-center gap-3 border-b border-border-color/30 pb-3">
				<div class="w-2.5 h-6 bg-brand-500 rounded-full"></div>
				<h2 class="text-xl font-bold text-text-main">Official Brand Assets</h2>
			</div>

			<div class="grid sm:grid-cols-3 gap-6">
				<!-- Brand Mark Card -->
				<div class="bg-card-bg border border-border-color/35 p-6 rounded-2xl flex flex-col items-center justify-center text-center space-y-4 shadow-sm">
					<div class="w-16 h-16 bg-brand-500 rounded-2xl flex items-center justify-center text-white text-3xl font-black shadow-md shadow-brand-500/10">
						{SITE_CONFIG.branding.acronym}
					</div>
					<div class="space-y-1">
						<p class="text-sm font-bold text-text-main">Monogram Emblem</p>
						<p class="text-[10px] text-text-muted">High-res SVG, 512x512px</p>
					</div>
					<a href={base + "/favicon.svg"} download class="text-[11px] font-bold text-brand-500 hover:underline">Download Asset &rarr;</a>
				</div>

				<!-- Logo Mark Card -->
				<div class="bg-card-bg border border-border-color/35 p-6 rounded-2xl flex flex-col items-center justify-center text-center space-y-4 shadow-sm">
					<div class="h-16 px-4 bg-black/5 dark:bg-white/5 border border-border-color/40 rounded-2xl flex items-center justify-center gap-2">
						<div class="w-7 h-7 bg-gray-900 dark:bg-white rounded-lg flex items-center justify-center text-white dark:text-black font-black text-sm">
							{SITE_CONFIG.branding.acronym}
						</div>
						<span class="text-sm font-bold text-text-main">{SITE_CONFIG.branding.name}</span>
					</div>
					<div class="space-y-1">
						<p class="text-sm font-bold text-text-main">Global Logo Lockup</p>
						<p class="text-[10px] text-text-muted">Transparent PNG format</p>
					</div>
					<a href={base + "/favicon.svg"} download class="text-[11px] font-bold text-brand-500 hover:underline">Download Asset &rarr;</a>
				</div>

				<!-- Brand Colors Card -->
				<div class="bg-card-bg border border-border-color/35 p-6 rounded-2xl flex flex-col items-center justify-center text-center space-y-4 shadow-sm">
					<div class="flex items-center gap-2.5 h-16">
						<div class="w-8 h-8 rounded-xl bg-brand-500 border border-white/10 shadow-sm"></div>
						<div class="w-8 h-8 rounded-xl bg-[#050505] border border-white/10 shadow-sm"></div>
						<div class="w-8 h-8 rounded-xl bg-[#111111] border border-white/10 shadow-sm"></div>
					</div>
					<div class="space-y-1">
						<p class="text-sm font-bold text-text-main">Official Brand Colors</p>
						<p class="text-[10px] text-text-muted">HEX values and palettes</p>
					</div>
					<span class="text-[11px] font-bold text-text-muted uppercase tracking-widest">HSL Specs</span>
				</div>
			</div>
		</div>

		<!-- Footer Media Inquiries Contact -->
		<div class="relative bg-card-bg border border-border-color/40 rounded-3xl p-8 shadow-sm overflow-hidden text-center space-y-4">
			<div class="absolute -top-12 -right-12 w-40 h-40 bg-brand-500/5 rounded-full blur-3xl"></div>
			<div class="max-w-md mx-auto space-y-2 relative z-10">
				<h3 class="text-lg font-bold text-text-main">Media & Press Inquiries</h3>
				<p class="text-xs text-text-muted leading-relaxed">
					Are you reviewing {SITE_CONFIG.branding.name} or seeking standard high-resolution graphic templates, interviews, or engineering briefs? Connect directly via the portal coordinator.
				</p>
				<div class="pt-3">
					<a href={base + "/contact"} class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-500 text-white rounded-xl text-xs font-bold hover:bg-brand-600 transition-colors shadow-sm outline-none">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
						Contact Public Relations
					</a>
				</div>
			</div>
		</div>
	</div>
</Layout>
