---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../config/site';

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout title="Press & Media Kit" description="Access official media resources, press kits, and promotional web video editors for CanvasLabs.">
  <div class="max-w-5xl w-full mx-auto py-12 px-4 sm:px-6 lg:px-8 space-y-20">
    
    <!-- Top Nav / Back Action -->
    <div class="flex items-center justify-between border-b border-border-color/10 pb-6">
      <div class="flex items-center gap-6">
        <a href={base + "/"} class="inline-flex items-center gap-2.5 text-xs font-black uppercase tracking-widest text-text-muted hover:text-brand-500 transition-colors group">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          Back to Workspace
        </a>
        <a href={base + "/landing"} class="inline-flex items-center gap-2.5 text-xs font-black uppercase tracking-widest text-text-muted hover:text-brand-500 transition-colors group border-l border-border-color/30 pl-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" /><path d="M3 9h18" /><path d="M9 21V9" /></svg>
          View Landing Page
        </a>
      </div>
      <span class="text-[10px] font-black uppercase tracking-widest text-brand-500 bg-brand-500/10 border border-brand-500/20 px-3 py-1 rounded-full">
        Press Kit
      </span>
    </div>

    <!-- Editorial Hero Header -->
    <div class="max-w-3xl space-y-4">
      <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-text-main leading-[1.1] font-sans">
        CanvasLabs <span class="text-brand-500">Media Resources</span> & Kits.
      </h1>
      <p class="text-sm sm:text-base text-text-muted leading-relaxed max-w-2xl font-medium">
        Official brand guidelines, interactive design editor portals, and high-fidelity assets carefully curated for publishers, creators, and reviewers.
      </p>
    </div>

    <!-- Section 1: Interactive Showcases -->
    <div class="space-y-8">
      <div class="flex flex-col gap-1.5 border-l-2 border-brand-500 pl-4">
        <h2 class="text-xs font-black text-text-main uppercase tracking-widest">Interactive Portals</h2>
        <p class="text-[11px] text-text-muted font-medium">Click to launch live promotional editor design concepts.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 pt-2">
        <!-- Kenichi V1 Studio Portal -->
        <div class="group relative bg-black/[0.015] dark:bg-white/[0.01] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 rounded-3xl p-8 shadow-none hover:shadow-2xl hover:shadow-black/[0.01] dark:hover:shadow-white/[0.01] transition-all duration-500 flex flex-col justify-between hover:bg-black/[0.02] dark:hover:bg-white/[0.015] min-h-[320px]">
          <div class="space-y-5">
            <div class="flex items-center justify-between">
              <div class="w-11 h-11 rounded-2xl bg-black dark:bg-white flex items-center justify-center text-white dark:text-black font-black text-lg shadow-sm">
                K
              </div>
              <span class="text-[9px] font-black text-brand-500 bg-brand-500/10 px-2.5 py-1 rounded-md uppercase tracking-widest border border-brand-500/10">
                TIMELINE V1
              </span>
            </div>
            
            <div class="space-y-2">
              <h3 class="text-lg font-black text-text-main">
                Kenichi Studio <span class="font-normal text-text-muted">/ Standard</span>
              </h3>
              <p class="text-xs text-text-muted leading-relaxed font-medium">
                The classic high-fidelity dark-mode landing page designed to mimic premium desktop video editor timelines, panel navigators, and interactive audio waveforms.
              </p>
            </div>
          </div>

          <div class="pt-6">
            <a 
              href={base + "/kenichi"} 
              class="w-full inline-flex items-center justify-center gap-2 px-5 py-3.5 bg-white dark:bg-zinc-900 hover:bg-brand-500 hover:text-white dark:hover:bg-brand-500 dark:hover:text-white border border-border-color/60 dark:border-zinc-800/80 text-text-main rounded-2xl text-xs font-bold transition-all duration-300 shadow-sm"
            >
              Launch timeline V1
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </a>
          </div>
        </div>

        <!-- Kenichi V2 Matte Edition -->
        <div class="group relative bg-black/[0.015] dark:bg-white/[0.01] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 rounded-3xl p-8 shadow-none hover:shadow-2xl hover:shadow-black/[0.01] dark:hover:shadow-white/[0.01] transition-all duration-500 flex flex-col justify-between hover:bg-black/[0.02] dark:hover:bg-white/[0.015] min-h-[320px]">
          <div class="space-y-5">
            <div class="flex items-center justify-between">
              <div class="w-11 h-11 rounded-2xl bg-brand-500 flex items-center justify-center text-white font-black text-lg shadow-sm">
                K2
              </div>
              <span class="text-[9px] font-black text-green-500 bg-green-500/10 px-2.5 py-1 rounded-md uppercase tracking-widest border border-green-500/10">
                PRO TIMELINE V2
              </span>
            </div>
            
            <div class="space-y-2">
              <h3 class="text-lg font-black text-text-main">
                Kenichi Matte Pro <span class="font-normal text-text-muted">/ CapCut Theme</span>
              </h3>
              <p class="text-xs text-text-muted leading-relaxed font-medium">
                Premium matte charcoal theme matching authentic CapCut editor specifications. Includes interactive AI background remover slider simulation and real-time timeline playheads.
              </p>
            </div>
          </div>

          <div class="pt-6">
            <a 
              href={base + "/kenichi-v2"} 
              class="w-full inline-flex items-center justify-center gap-2 px-5 py-3.5 bg-brand-500/10 text-brand-500 hover:bg-brand-500 hover:text-white rounded-2xl text-xs font-bold transition-all duration-300 shadow-sm"
            >
              Launch matte V2
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </a>
          </div>
        </div>

        <!-- Logo Customizer Pro Tool -->
        <div class="group relative bg-black/[0.015] dark:bg-white/[0.01] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 rounded-3xl p-8 shadow-none hover:shadow-2xl hover:shadow-black/[0.01] dark:hover:shadow-white/[0.01] transition-all duration-500 flex flex-col justify-between hover:bg-black/[0.02] dark:hover:bg-white/[0.015] min-h-[320px]">
          <div class="space-y-5">
            <div class="flex items-center justify-between">
              <div class="w-11 h-11 rounded-2xl bg-brand-600 flex items-center justify-center text-white font-black text-lg shadow-sm">
                LC
              </div>
              <span class="text-[9px] font-black text-brand-500 bg-brand-500/10 px-2.5 py-1 rounded-md uppercase tracking-widest border border-brand-500/10">
                BRANDING V3
              </span>
            </div>
            
            <div class="space-y-2">
              <h3 class="text-lg font-black text-text-main">
                Pro Logo Customizer <span class="font-normal text-text-muted">/ Vector Studio</span>
              </h3>
              <p class="text-xs text-text-muted leading-relaxed font-medium">
                A fully client-side interactive branding tool enabling real-time font adjustments, custom drop shadows, radial gradient backdrops, and transparent 4K/Vector SVG exports.
              </p>
            </div>
          </div>

          <div class="pt-6">
            <a 
              href={base + "/tool/logo-customizer-v3"} 
              class="w-full inline-flex items-center justify-center gap-2 px-5 py-3.5 bg-brand-600 text-white hover:bg-brand-700 rounded-2xl text-xs font-bold transition-all duration-300 shadow-sm"
            >
              Launch Customizer
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </a>
          </div>
        </div>

        <!-- Favicon & Browser Tab Studio -->
        <div class="group relative bg-black/[0.015] dark:bg-white/[0.01] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 rounded-3xl p-8 shadow-none hover:shadow-2xl hover:shadow-black/[0.01] dark:hover:shadow-white/[0.01] transition-all duration-500 flex flex-col justify-between hover:bg-black/[0.02] dark:hover:bg-white/[0.015] min-h-[320px]">
          <div class="space-y-5">
            <div class="flex items-center justify-between">
              <div class="w-11 h-11 rounded-2xl bg-brand-500 flex items-center justify-center text-white font-black text-lg shadow-sm">
                FG
              </div>
              <span class="text-[9px] font-black text-brand-500 bg-brand-500/10 px-2.5 py-1 rounded-md uppercase tracking-widest border border-brand-500/10">
                FAVICON KIT
              </span>
            </div>
            
            <div class="space-y-2">
              <h3 class="text-lg font-black text-text-main">
                Browser Tab Studio <span class="font-normal text-text-muted">/ Monograms</span>
              </h3>
              <p class="text-xs text-text-muted leading-relaxed font-medium">
                A comprehensive favicon designer enabling text monograms, multi-resolution PNG/SVG vector kit creation, and premium real-time Chrome white/dark tab mockups.
              </p>
            </div>
          </div>

          <div class="pt-6">
            <a 
              href={base + "/tool/favicon-generator"} 
              class="w-full inline-flex items-center justify-center gap-2 px-5 py-3.5 bg-brand-500 text-white hover:bg-brand-600 rounded-2xl text-xs font-bold transition-all duration-300 shadow-sm"
            >
              Launch Favicon Kit
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Section 2: Official Assets -->
    <div class="space-y-8">
      <div class="flex flex-col gap-1.5 border-l-2 border-brand-500 pl-4">
        <h2 class="text-xs font-black text-text-main uppercase tracking-widest">Brand Kit & Guidelines</h2>
        <p class="text-[11px] text-text-muted font-medium">Download vector markings and view layout specifications.</p>
      </div>

      <div class="grid sm:grid-cols-3 gap-6 pt-2">
        <!-- Brand Mark Card -->
        <div class="bg-black/[0.01] dark:bg-white/[0.005] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 p-8 rounded-3xl flex flex-col items-center justify-center text-center space-y-5 transition-all duration-300 shadow-none hover:bg-black/[0.015] dark:hover:bg-white/[0.01]">
          <div class="w-16 h-16 bg-brand-500 rounded-2xl flex items-center justify-center text-white text-3xl font-black shadow-sm select-none">
            {SITE_CONFIG.branding.acronym}
          </div>
          <div class="space-y-1">
            <h4 class="text-xs font-bold text-text-main uppercase tracking-wider">Monogram Emblem</h4>
            <p class="text-[10px] text-text-muted font-medium">High-resolution SVG (scalable)</p>
          </div>
          <a href={base + "/favicon.svg"} download class="text-[10px] font-black uppercase tracking-wider text-brand-500 hover:text-brand-600 transition-colors">
            Download emblem &rarr;
          </a>
        </div>

        <!-- Logo Mark Card -->
        <div class="bg-black/[0.01] dark:bg-white/[0.005] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 p-8 rounded-3xl flex flex-col items-center justify-center text-center space-y-5 transition-all duration-300 shadow-none hover:bg-black/[0.015] dark:hover:bg-white/[0.01]">
          <div class="h-16 px-4 bg-black/5 dark:bg-white/5 border border-border-color/20 rounded-2xl flex items-center justify-center gap-2.5 select-none">
            <div class="w-6.5 h-6.5 bg-gray-900 dark:bg-white rounded-md flex items-center justify-center text-white dark:text-black font-black text-[11px]">
              {SITE_CONFIG.branding.acronym}
            </div>
            <span class="text-xs font-black text-text-main tracking-tight">{SITE_CONFIG.branding.name}</span>
          </div>
          <div class="space-y-1">
            <h4 class="text-xs font-bold text-text-main uppercase tracking-wider">Global Logo Lockup</h4>
            <p class="text-[10px] text-text-muted font-medium">Transparent styling branding</p>
          </div>
          <a href={base + "/favicon.svg"} download class="text-[10px] font-black uppercase tracking-wider text-brand-500 hover:text-brand-600 transition-colors">
            Download lockup &rarr;
          </a>
        </div>

        <!-- Brand Colors Card -->
        <div class="bg-black/[0.01] dark:bg-white/[0.005] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 p-8 rounded-3xl flex flex-col items-center justify-center text-center space-y-5 transition-all duration-300 shadow-none hover:bg-black/[0.015] dark:hover:bg-white/[0.01]">
          <div class="flex items-center gap-3 h-16 select-none">
            <div class="w-8 h-8 rounded-xl bg-brand-500 border border-white/10 shadow-sm" title="Brand Primary"></div>
            <div class="w-8 h-8 rounded-xl bg-[#090909] border border-white/10 dark:border-zinc-700 shadow-sm" title="Neutral Dark"></div>
            <div class="w-8 h-8 rounded-xl bg-[#F8FAFC] border border-black/10 dark:border-zinc-800 shadow-sm" title="Neutral Light"></div>
          </div>
          <div class="space-y-1">
            <h4 class="text-xs font-bold text-text-main uppercase tracking-wider">Official Palette</h4>
            <p class="text-[10px] text-text-muted font-medium">HEX / HSL Color Spec Kit</p>
          </div>
          <span class="text-[9px] font-black uppercase tracking-widest text-text-muted bg-black/5 dark:bg-white/5 border border-border-color/10 px-2 py-0.5 rounded">
            HSL Configured
          </span>
        </div>
      </div>
    </div>

    <!-- Contact & PR Segment -->
    <div class="bg-black/[0.015] dark:bg-white/[0.01] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 rounded-[32px] p-8 sm:p-12 text-center max-w-4xl mx-auto space-y-5 shadow-none">
      <div class="max-w-2xl mx-auto space-y-3.5">
        <h3 class="text-xl sm:text-2xl font-black text-text-main">Media Inquiries & Review Kit Requests</h3>
        <p class="text-xs sm:text-sm text-text-muted leading-relaxed font-medium">
          Seeking early preview builds, interviews with engineers, high-resolution vector assets, or documentation briefings regarding {SITE_CONFIG.branding.name}? Reach out directly to our communications desk.
        </p>
        <div class="pt-4 flex items-center justify-center">
          <a href={base + "/contact"} class="inline-flex items-center gap-2 px-6 py-3.5 bg-brand-500 text-white rounded-2xl text-xs font-black uppercase tracking-wider hover:bg-brand-600 transition-colors shadow-sm outline-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            Contact Communications
          </a>
        </div>
      </div>
    </div>

  </div>
</Layout>

