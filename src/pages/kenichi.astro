---
import '@/styles/global.css';
import { SITE_CONFIG } from '@/config/site';
import Favicon from '@/components/Favicon.astro';

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <Favicon />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kenichi | Next-Gen Web Video Editor</title>
    <meta name="description" content="Everything you need to create high-quality videos right in your browser. From smart cutting to AI effects, Kenichi makes pro editing accessible to everyone." />
    
    <!-- Google Fonts: Outfit & Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web" is:inline></script>

    <!-- Tailwind Config & custom classes -->
    <style is:global>
        :root {
            --brand-color: #5c80ff;
            --brand-glow: rgba(92, 128, 255, 0.25);
            --bg-color: #0b0b0d;
            --surface-bg: #141416;
            --surface-panel: #1e1e22;
            --surface-border: rgba(255, 255, 255, 0.06);
            --text-main: #ffffff;
            --text-muted: #8e8e93;
        }

        body {
            background-color: var(--bg-color) !important;
            color: var(--text-main) !important;
            font-family: 'Inter', sans-serif !important;
            overflow-x: hidden !important;
        }

        /* Smooth scroll animations */
        .reveal {
            opacity: 0;
            transform: translateY(24px);
            transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* Custom text gradient */
        .text-gradient {
            background: linear-gradient(135deg, #ffffff 0%, #a1a1aa 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .text-gradient-brand {
            background: linear-gradient(135deg, #8ca8ff 0%, #b3c7ff 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Ambient Glow Effect */
        .glow-overlay {
            filter: blur(140px);
            pointer-events: none;
            opacity: 0.8;
        }

        /* Glassmorphism nav */
        .glass-nav {
            background: rgba(11, 11, 13, 0.75);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--surface-border);
        }

        /* CapCut pill badge */
        .pill-badge {
            background: linear-gradient(90deg, rgba(92, 128, 255, 0.12) 0%, rgba(140, 168, 255, 0.05) 100%);
            border: 1px solid rgba(92, 128, 255, 0.25);
        }

        /* Feature cards hovers */
        .feature-card {
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s ease, background-color 0.4s ease;
        }
        .feature-card:hover {
            transform: translateY(-6px);
            border-color: rgba(92, 128, 255, 0.35);
            background-color: var(--surface-panel);
        }

        /* Custom Scrollbar for inner viewport mockups */
        .custom-editor-scrollbar::-webkit-scrollbar {
            width: 4px;
            height: 4px;
        }
        .custom-editor-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-editor-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 8px;
        }
    </style>
</head>
<body class="antialiased selection:bg-[#5c80ff] selection:text-white relative">

    <!-- Ambient Background Glows -->
    <div class="fixed top-[-25%] left-[-15%] w-[60%] h-[55%] rounded-full bg-[#3d63ff]/10 glow-overlay z-0"></div>
    <div class="fixed bottom-[-20%] right-[-10%] w-[50%] h-[50%] rounded-full bg-[#8ca8ff]/5 glow-overlay z-0"></div>

    <!-- Navigation Bar -->
    <nav class="fixed w-full z-50 top-0 glass-nav">
        <div class="max-w-7xl mx-auto px-6 h-[72px] flex items-center justify-between">
            <!-- Brand Logo -->
            <a href={base + "/"} class="flex items-center gap-3 group outline-none">
                <div class="w-8 h-8 rounded-lg bg-white flex items-center justify-center text-black font-black text-xl tracking-tighter">
                    K
                </div>
                <div class="flex flex-col">
                    <span class="font-bold text-lg tracking-tight leading-none">Kenichi</span>
                    <span class="text-[9px] text-[#8e8e93] font-semibold uppercase tracking-widest mt-1">Video Studio</span>
                </div>
            </a>

            <!-- Navigation Links -->
            <div class="hidden md:flex items-center gap-8 text-[14px] font-medium text-gray-300">
                <a href="#features" class="hover:text-white transition-colors">Features</a>
                <a href="#ai-tools" class="hover:text-white transition-colors">AI Tools</a>
                <a href="#mockup" class="hover:text-white transition-colors">Workspace</a>
                <a href={base + "/"} class="text-[#5c80ff] hover:text-[#8ca8ff] transition-colors flex items-center gap-1.5 font-semibold">
                    <i class="ph ph-arrow-left"></i> Back to Hub
                </a>
            </div>

            <!-- CTA Actions -->
            <div class="flex items-center gap-4">
                <a href={base + "/"} class="text-[14px] font-semibold text-gray-300 hover:text-white transition-colors hidden sm:block">Back to Portal</a>
                <a href="#mockup" class="px-5 py-2 text-[13px] font-bold rounded-full bg-white text-black hover:bg-gray-100 transition-all active:scale-95">
                    Launch App
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Wrapper -->
    <main class="relative z-10 pt-28 pb-16">
        
        <!-- Hero Promotion Section -->
        <section class="max-w-7xl mx-auto px-6 pt-12 pb-20 text-center reveal active">
            <!-- CapCut Auto-Caption Alert Badge -->
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full pill-badge text-[#8ca8ff] text-xs font-semibold mb-8 select-none">
                <i class="ph-fill ph-sparkle text-[#5c80ff] animate-pulse"></i>
                V0.9.4 LIVE: Next-Generation WebAnimator Pipeline
            </div>
            
            <h1 class="text-4xl md:text-7xl font-extrabold tracking-tight mb-6 leading-[1.12]">
                <span class="text-gradient">Free Web Video Editor.</span><br>
                <span class="text-gradient-brand">Magic tools, effortless creation.</span>
            </h1>
            
            <p class="text-base md:text-lg text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed font-normal">
                Everything you need to create high-quality cinematic videos right in your local browser. Equipped with solid-state rendering engines, reactive timelines, and powerful auto-caption pipelines.
            </p>
            
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 max-w-sm sm:max-w-md mx-auto">
                <a href="#mockup" class="w-full sm:w-auto px-8 py-3.5 rounded-full bg-white text-black font-bold hover:bg-gray-200 transition-all text-sm flex items-center justify-center gap-2">
                    <i class="ph-fill ph-play-circle text-lg"></i>
                    Start Editing Online
                </a>
                <a href="https://github.com/simplearyan" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto px-8 py-3.5 rounded-full bg-[#1e1e22] hover:bg-[#2a2a30] border border-white/5 text-white font-bold transition-all text-sm flex items-center justify-center gap-2">
                    <i class="ph ph-github-logo text-lg"></i>
                    View Source
                </a>
            </div>

            <!-- High-Fidelity Interface Mockup -->
            <div id="mockup" class="relative w-full max-w-[1000px] mx-auto reveal mt-8">
                <div class="absolute -inset-1.5 bg-gradient-to-br from-[#3d63ff]/20 to-[#8c8cff]/20 rounded-2xl blur-xl opacity-60"></div>
                
                <!-- Mockup App Frame -->
                <div class="relative rounded-2xl bg-[#0e0e11] border border-white/10 shadow-[0_24px_60px_rgba(0,0,0,0.75)] overflow-hidden flex flex-col h-[520px]">
                    
                    <!-- Mac Window TopBar controls -->
                    <div class="h-12 bg-[#131316] border-b border-white/5 flex items-center px-4 justify-between select-none">
                        <div class="flex gap-2">
                             <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
                             <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
                             <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
                        </div>
                        <div class="text-xs text-gray-400 font-bold tracking-wide">Kenichi Studio — Cinematic Motion Graphics</div>
                        <div class="flex items-center gap-2">
                            <span class="px-2 py-0.5 bg-[#5c80ff]/10 text-[#8ca8ff] border border-[#5c80ff]/20 rounded text-[9px] font-extrabold tracking-widest uppercase">WebWorker-Active</span>
                            <div class="h-4 w-px bg-white/5 mx-1"></div>
                            <button class="px-3.5 py-1.5 rounded-lg bg-white text-black hover:bg-gray-200 text-xs font-bold transition-colors">Export 4K</button>
                        </div>
                    </div>

                    <!-- Editor Panels Container -->
                    <div class="flex-1 flex overflow-hidden">
                        
                        <!-- Left Action Bar -->
                        <div class="w-16 bg-[#111113] border-r border-white/5 flex flex-col items-center py-6 gap-6 text-gray-500 shrink-0">
                            <div class="p-2.5 rounded-xl bg-[#5c80ff]/10 text-white"><i class="ph ph-folder text-lg"></i></div>
                            <div class="p-2.5 rounded-xl hover:bg-white/5 hover:text-white transition-colors cursor-pointer"><i class="ph ph-scissors text-lg"></i></div>
                            <div class="p-2.5 rounded-xl hover:bg-white/5 hover:text-white transition-colors cursor-pointer"><i class="ph ph-text-t text-lg"></i></div>
                            <div class="p-2.5 rounded-xl hover:bg-white/5 hover:text-white transition-colors cursor-pointer"><i class="ph ph-music-notes text-lg"></i></div>
                            <div class="p-2.5 rounded-xl hover:bg-white/5 hover:text-white transition-colors cursor-pointer"><i class="ph ph-sparkle text-lg"></i></div>
                            <div class="p-2.5 rounded-xl hover:bg-white/5 hover:text-white transition-colors cursor-pointer mt-auto"><i class="ph ph-gear text-lg"></i></div>
                        </div>

                        <!-- Canvas Workspace -->
                        <div class="flex-1 flex flex-col bg-[#0b0b0d]">
                            <!-- Main Video Preview Viewport -->
                            <div class="flex-1 p-6 flex items-center justify-center bg-[url('https://placehold.co/20x20/0a0a0c/111113?text=+')] bg-repeat">
                                <div class="w-full max-w-[620px] aspect-video bg-black rounded-xl shadow-2xl relative overflow-hidden flex items-center justify-center border border-white/10 group">
                                    <img src="https://images.unsplash.com/photo-1511512578047-dfb367046420?q=80&w=1200&auto=format&fit=crop" class="w-full h-full object-cover opacity-75" alt="Cinematic Video Preview Workspace">
                                    
                                    <!-- Cinematic play overlay -->
                                    <div class="absolute inset-0 flex items-center justify-center bg-black/25 group-hover:bg-black/35 transition-colors">
                                         <i class="ph-fill ph-play-circle text-6xl text-white/95 drop-shadow-xl hover:scale-105 transition-transform cursor-pointer"></i>
                                    </div>
                                    
                                    <!-- Media controls overlay -->
                                    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 bg-black/75 backdrop-blur-md px-4 py-2.5 rounded-full border border-white/10 flex items-center gap-4 text-white text-xs select-none">
                                        <i class="ph-fill ph-play cursor-pointer hover:text-[#8ca8ff] transition-colors"></i>
                                        <div class="w-36 h-1 bg-white/15 rounded-full relative overflow-hidden">
                                            <div class="w-1/3 h-full bg-[#5c80ff] rounded-full"></div>
                                        </div>
                                        <span class="font-mono text-[10px] text-gray-300">00:24 / 01:15</span>
                                        <i class="ph ph-corners-out cursor-pointer hover:text-[#8ca8ff] transition-colors"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Timeline Tracks Panel -->
                            <div class="h-44 bg-[#111113] border-t border-white/5 flex flex-col overflow-y-auto custom-editor-scrollbar select-none">
                                <!-- Track Timings Header -->
                                <div class="h-6 border-b border-white/5 px-4 flex items-center text-[9px] text-gray-500 font-mono tracking-wider">
                                    <span class="w-8 shrink-0 text-center">T</span>
                                    <span class="ml-4">00:00</span>
                                    <span class="ml-24">00:15</span>
                                    <span class="ml-24">00:30</span>
                                    <span class="ml-24">00:45</span>
                                    <span class="ml-24">01:00</span>
                                </div>
                                
                                <div class="flex-1 p-2.5 flex flex-col gap-2 relative">
                                    <!-- Dynamic Vertical Playhead -->
                                    <div class="absolute top-0 bottom-0 w-px bg-white z-20 left-[35%] pointer-events-none">
                                        <div class="w-2.5 h-3.5 bg-white absolute top-0 -left-[4.5px] rounded-b-sm shadow-md"></div>
                                    </div>

                                    <!-- Video Core Track -->
                                    <div class="flex h-11 w-full items-center gap-3">
                                        <div class="w-8 shrink-0 flex justify-center text-gray-500"><i class="ph ph-video-camera text-sm"></i></div>
                                        <div class="flex-1 flex gap-1 h-full">
                                            <div class="h-full w-[35%] bg-blue-900/35 border border-blue-500/25 rounded-lg overflow-hidden relative">
                                                <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1511512578047-dfb367046420?q=10&w=200&auto=format&fit=crop')] bg-cover opacity-20"></div>
                                                <span class="absolute left-2.5 bottom-1 text-[9px] text-blue-200/80 font-bold font-mono">clip_01.mp4</span>
                                            </div>
                                            <div class="h-full w-[45%] bg-blue-900/35 border border-blue-500/25 rounded-lg border-l-2 border-l-white overflow-hidden relative">
                                                 <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1511512578047-dfb367046420?q=10&w=200&auto=format&fit=crop')] bg-cover opacity-45"></div>
                                                 <span class="absolute left-2.5 bottom-1 text-[9px] text-blue-200/80 font-bold font-mono">clip_02.mp4</span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Audio Sound Track -->
                                    <div class="flex h-9 w-full items-center gap-3">
                                        <div class="w-8 shrink-0 flex justify-center text-gray-500"><i class="ph ph-speaker-high text-sm"></i></div>
                                        <div class="flex-1 flex gap-1 h-full">
                                            <div class="h-full w-[80%] bg-[#5c80ff]/20 border border-[#5c80ff]/20 rounded-lg flex items-center overflow-hidden">
                                                 <!-- Waveform visualization representation -->
                                                 <div class="w-full h-4 flex items-center gap-[2.5px] px-3 opacity-60">
                                                    <div class="w-[3px] h-full bg-[#8ca8ff] rounded-full"></div>
                                                    <div class="w-[3px] h-1/2 bg-[#8ca8ff] rounded-full"></div>
                                                    <div class="w-[3px] h-3/4 bg-[#8ca8ff] rounded-full"></div>
                                                    <div class="w-[3px] h-1/4 bg-[#8ca8ff] rounded-full"></div>
                                                    <div class="w-[3px] h-full bg-[#8ca8ff] rounded-full"></div>
                                                    <div class="w-[3px] h-2/3 bg-[#8ca8ff] rounded-full"></div>
                                                    <div class="w-[3px] h-1/2 bg-[#8ca8ff] rounded-full"></div>
                                                    <div class="w-[3px] h-3/4 bg-[#8ca8ff] rounded-full"></div>
                                                    <div class="w-[3px] h-full bg-[#8ca8ff] rounded-full"></div>
                                                    <div class="w-[3px] h-1/2 bg-[#8ca8ff] rounded-full"></div>
                                                    <div class="w-[3px] h-3/4 bg-[#8ca8ff] rounded-full"></div>
                                                    <div class="w-[3px] h-1/4 bg-[#8ca8ff] rounded-full"></div>
                                                 </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Smart Auto Captions Track -->
                                    <div class="flex h-7 w-full items-center gap-3">
                                        <div class="w-8 shrink-0 flex justify-center text-gray-500"><i class="ph ph-text-t text-sm"></i></div>
                                        <div class="flex-1 flex gap-1 h-full">
                                            <div class="h-full w-[45%] ml-[15%] bg-purple-900/30 border border-purple-500/25 rounded-md flex items-center px-2.5">
                                                <span class="text-[9px] font-semibold text-purple-200 tracking-wider">Subtitle Caption #01</span>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Product Features highlights Grid -->
        <section id="features" class="max-w-7xl mx-auto px-6 py-24 border-t border-white/5 relative">
            <div class="absolute -top-40 -left-40 w-80 h-80 bg-[#3d63ff]/5 rounded-full blur-[140px] pointer-events-none"></div>
            
            <div class="text-center mb-20 reveal">
                <span class="text-xs font-black text-[#5c80ff] uppercase tracking-widest">Editing Redefined</span>
                <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight mt-3 mb-4">Powerful tools, simple interface</h2>
                <p class="text-gray-400 max-w-2xl mx-auto text-sm leading-relaxed">
                    Everything you need to craft high-quality cinematic videos is right at your fingertips inside your web browser.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Highlight 1 -->
                <div class="feature-card bg-[#141416] border border-white/5 p-8 rounded-3xl reveal">
                    <div class="w-12 h-12 rounded-2xl bg-blue-500/10 flex items-center justify-center text-blue-400 text-2xl mb-6">
                        <i class="ph ph-scissors"></i>
                    </div>
                    <h3 class="text-lg font-bold mb-2.5 text-white">Basic Editing</h3>
                    <p class="text-gray-400 text-xs leading-relaxed">
                        Trim, crop, split, and merge clips with absolute frame-by-frame precision on an intuitive timeline track structure.
                    </p>
                </div>

                <!-- Highlight 2 -->
                <div class="feature-card bg-[#141416] border border-white/5 p-8 rounded-3xl reveal">
                    <div class="w-12 h-12 rounded-2xl bg-purple-500/10 flex items-center justify-center text-purple-400 text-2xl mb-6">
                        <i class="ph ph-magic-wand"></i>
                    </div>
                    <h3 class="text-lg font-bold mb-2.5 text-white">Smart Tools</h3>
                    <p class="text-gray-400 text-xs leading-relaxed">
                        Remove video backgrounds in one click, upscale dynamic images, and auto-frame your subjects seamlessly.
                    </p>
                </div>

                <!-- Highlight 3 -->
                <div class="feature-card bg-[#141416] border border-white/5 p-8 rounded-3xl reveal">
                    <div class="w-12 h-12 rounded-2xl bg-[#5c80ff]/10 flex items-center justify-center text-[#8ca8ff] text-2xl mb-6">
                        <i class="ph ph-closed-captioning"></i>
                    </div>
                    <h3 class="text-lg font-bold mb-2.5 text-white">Auto Captions</h3>
                    <p class="text-gray-400 text-xs leading-relaxed">
                        Automatically transcribe and translate audio signals into stylish, customizable, and perfectly timed subtitles.
                    </p>
                </div>
                
                <!-- Highlight 4 -->
                <div class="feature-card bg-[#141416] border border-white/5 p-8 rounded-3xl reveal">
                    <div class="w-12 h-12 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 text-2xl mb-6">
                        <i class="ph ph-music-notes"></i>
                    </div>
                    <h3 class="text-lg font-bold mb-2.5 text-white">Rich Resources</h3>
                    <p class="text-gray-400 text-xs leading-relaxed">
                        Access thousands of copyright-free audio tracks, transitions, stickers, overlays, and text presets.
                    </p>
                </div>

                <!-- Highlight 5 -->
                <div class="feature-card bg-[#141416] border border-white/5 p-8 rounded-3xl reveal">
                    <div class="w-12 h-12 rounded-2xl bg-amber-500/10 flex items-center justify-center text-amber-400 text-2xl mb-6">
                        <i class="ph ph-faders"></i>
                    </div>
                    <h3 class="text-lg font-bold mb-2.5 text-white">Filters & Effects</h3>
                    <p class="text-gray-400 text-xs leading-relaxed">
                        Apply cinematic color grading filters, custom speed ramps, and trendy visual motion graphic effects.
                    </p>
                </div>

                <!-- Highlight 6 -->
                <div class="feature-card bg-[#141416] border border-white/5 p-8 rounded-3xl reveal">
                    <div class="w-12 h-12 rounded-2xl bg-pink-500/10 flex items-center justify-center text-pink-400 text-2xl mb-6">
                        <i class="ph ph-export"></i>
                    </div>
                    <h3 class="text-lg font-bold mb-2.5 text-white">High-Quality Export</h3>
                    <p class="text-gray-400 text-xs leading-relaxed">
                        Export videos in crisp 4K 60fps. Optimize configurations instantly for TikTok, YouTube, and Reels grids.
                    </p>
                </div>
            </div>
        </section>

        <!-- AI Capabilities Split Presentation -->
        <section id="ai-tools" class="max-w-7xl mx-auto px-6 py-24 border-t border-white/5 overflow-hidden relative">
            <div class="absolute -bottom-40 -right-40 w-80 h-80 bg-[#8c8cff]/5 rounded-full blur-[140px] pointer-events-none"></div>

            <div class="flex flex-col lg:flex-row items-center gap-16">
                <!-- Text Detail -->
                <div class="flex-1 reveal">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md bg-[#1e1e22] text-[#8ca8ff] text-[10px] font-bold uppercase tracking-wider mb-6">
                        <i class="ph-fill ph-lightning"></i> AI Powered Processing
                    </div>
                    <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-6 leading-tight">Edit smarter,<br>not harder.</h2>
                    <p class="text-gray-400 text-sm leading-relaxed mb-8">
                        Kenichi's built-in AI models handle the tedious cutting and upscaling processes, leaving you full creative freedom. Remove video backdrops in real-time, isolate speaker voices, and suppress background noise instantly.
                    </p>
                    <ul class="space-y-4 mb-8">
                        <li class="flex items-center gap-3 text-sm text-gray-300">
                            <i class="ph-fill ph-check-circle text-[#5c80ff] text-lg"></i>
                            One-click Background Removal
                        </li>
                        <li class="flex items-center gap-3 text-sm text-gray-300">
                            <i class="ph-fill ph-check-circle text-[#5c80ff] text-lg"></i>
                            Voice Isolation & Noise Suppression
                        </li>
                        <li class="flex items-center gap-3 text-sm text-gray-300">
                            <i class="ph-fill ph-check-circle text-[#5c80ff] text-lg"></i>
                            Smart Video Auto-Stabilization
                        </li>
                    </ul>
                    <a href="https://github.com/simplearyan" target="_blank" rel="noopener noreferrer" class="text-white text-xs font-bold flex items-center gap-2 hover:text-[#8ca8ff] transition-colors outline-none cursor-pointer">
                        Explore all AI tools <i class="ph ph-arrow-right"></i>
                    </a>
                </div>
                
                <!-- Interactive split visual showcase -->
                <div class="flex-1 relative reveal">
                    <div class="relative w-full aspect-square max-w-sm sm:max-w-md mx-auto">
                        <div class="absolute inset-0 bg-gradient-to-br from-[#3d63ff]/15 to-[#c084fc]/15 rounded-full blur-3xl"></div>
