---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../config/site';
---

<Layout title="Contact Developer" description={`Get in touch with Aryan (simplearyan), the lead developer of ${SITE_CONFIG.branding.name}.`}>
	<!-- Back link -->
	<a href="/" class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-brand-500 transition-colors group mb-4">
		<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
		Back to Hub
	</a>

	<!-- Simplified Centered Container -->
	<div class="max-w-xl w-full mx-auto space-y-8 py-4">
		<!-- Header -->
		<div class="text-center space-y-3">
			<h1 class="text-4xl font-extrabold tracking-tight text-text-main font-sans">Contact Developer</h1>
			<p class="text-sm text-text-muted max-w-sm mx-auto leading-relaxed">
				Have questions or collaboration proposals? Connect directly with the interface architect.
			</p>
		</div>

		<!-- Premium Glass Card -->
		<div class="relative bg-card-bg border border-border-color/40 rounded-3xl p-8 shadow-sm overflow-hidden group">
			<!-- Glowing decorative background blur -->
			<div class="absolute -top-12 -right-12 w-40 h-40 bg-brand-500/10 rounded-full blur-3xl group-hover:bg-brand-500/20 transition-all duration-500"></div>
			<div class="absolute -bottom-12 -left-12 w-40 h-40 bg-brand-500/5 rounded-full blur-3xl group-hover:bg-brand-500/10 transition-all duration-500"></div>
			
			<div class="flex flex-col items-center text-center space-y-6 relative z-10">
				<!-- Profile Avatar Badge -->
				<div class="relative w-24 h-24 rounded-full bg-brand-500/10 flex items-center justify-center border border-brand-500/20">
					<span class="text-4xl font-black text-brand-500 select-none">A</span>
					<div class="absolute bottom-0 right-1 w-6 h-6 bg-green-500 rounded-full border-4 border-card-bg animate-pulse"></div>
				</div>

				<!-- Details -->
				<div class="space-y-1">
					<h3 class="text-2xl font-bold text-text-main">Aryan</h3>
					<p class="text-xs font-semibold text-brand-500 uppercase tracking-widest mt-0.5">Interface Architect & Engineer</p>
				</div>

				<p class="text-sm text-text-muted leading-relaxed max-w-md">
					Specializes in designing high-fidelity interactive templates, solid-state rendering engines, custom WebWorker compression structures, and responsive dark-mode workflows.
				</p>

				<!-- Developer Coordinates -->
				<div class="w-full pt-4 border-t border-border-color/30 space-y-3.5">
					<!-- Primary Action: GitHub Profile -->
					<a 
						href="https://github.com/simplearyan" 
						target="_blank" 
						rel="noopener noreferrer" 
						class="w-full flex items-center justify-center gap-2.5 px-5 py-3.5 bg-black dark:bg-white text-white dark:text-black rounded-2xl text-sm font-bold cursor-pointer outline-none"
					>
						<svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
							<path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
						</svg>
						Connect on GitHub (simplearyan)
					</a>

					<!-- Secondary Action: GitHub Issues/Collaboration -->
					<a 
						href="https://github.com/simplearyan" 
						target="_blank" 
						rel="noopener noreferrer" 
						class="w-full flex items-center justify-center gap-2 px-5 py-3.5 bg-brand-500/10 text-brand-500 rounded-2xl text-sm font-bold cursor-pointer outline-none"
					>
						<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
						Open a Collaboration Ticket
					</a>
				</div>
			</div>
		</div>

		<!-- Simplified footer details -->
		<div class="text-center text-xs text-text-muted leading-relaxed max-w-sm mx-auto space-y-1">
			<p class="font-semibold text-text-main">Global Response Window</p>
			<p>Typically replies within 24 hours via GitHub tickets or pull requests.</p>
		</div>
	</div>
</Layout>
