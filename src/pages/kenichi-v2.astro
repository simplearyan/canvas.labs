    <!-- Interactive Reveal & Drag Scroller Script -->
    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            // Scroll reveal observer
            const observerOptions = {
                root: null,
                rootMargin: '0px',
                threshold: 0.1
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, observerOptions);

            const revealElements = document.querySelectorAll('.reveal-v2');
            revealElements.forEach(el => observer.observe(el));

            // Background Removal Interactive Split slider controller
            const splitSlider = document.getElementById('splitSlider');
            const clippedImage = document.getElementById('clippedImage');
            const dividerLine = document.getElementById('dividerLine');

            if (splitSlider && clippedImage && dividerLine) {
                const updateSliderPosition = (val) => {
                    clippedImage.style.clipPath = `inset(0 0 0 ${val}%)`;
                    dividerLine.style.left = `${val}%`;
                };

                splitSlider.addEventListener('input', (e) => {
                    updateSliderPosition(e.target.value);
                });
            }
        });
    </script>
