---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../config/site';

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout title="Living Design Tools for Creators" description="Describe your creative vision and watch it turn into reusable, interactive vector design tools and templates." useSecondaryLayout={false}>
  <!-- Interactive Header Marquee & Brand Emblem -->
  <header class="w-full bg-black text-white py-3 overflow-hidden flex items-center relative z-40 border-b border-white/10">
    <div class="marquee-container w-full">
      <div class="marquee-content text-[10px] font-black tracking-widest uppercase items-center shrink-0 flex gap-12 animate-marquee">
        <span>Explore All Editors <span class="text-brand-500">→</span></span>
        <span>Typography Studio <span class="text-brand-500">→</span></span>
        <span>Interactive Chart Animator <span class="text-brand-500">→</span></span>
        <span>Favicon Monogram Generator <span class="text-brand-500">→</span></span>
        <span>Dynamic Brand Customizer <span class="text-brand-500">→</span></span>
        
        <!-- Duplicated for seamless loop -->
        <span>Explore All Editors <span class="text-brand-500">→</span></span>
        <span>Typography Studio <span class="text-brand-500">→</span></span>
        <span>Interactive Chart Animator <span class="text-brand-500">→</span></span>
        <span>Favicon Monogram Generator <span class="text-brand-500">→</span></span>
        <span>Dynamic Brand Customizer <span class="text-brand-500">→</span></span>
      </div>
    </div>
    
    <!-- Float Logo Pill -->
    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-white dark:bg-zinc-900 text-black dark:text-white px-5 py-2.5 rounded-full flex items-center gap-2 font-black tracking-tighter text-sm shadow-xl z-50 border border-black/5 dark:border-white/10 select-none">
      CANVAS LABS <span class="bg-brand-500 text-white text-[8px] px-2 py-0.5 rounded font-black tracking-wider uppercase">STUDIO</span>
    </div>
  </header>

  <!-- Spacious Main Grid (Full Width Spec) -->
  <div class="w-full max-w-[1600px] mx-auto py-12 px-4 sm:px-8 lg:px-12 space-y-24">

    <!-- Interactive Particle Hero Section -->
    <section class="relative pt-6 pb-12 flex flex-col items-center justify-start text-center z-10 space-y-8 max-w-5xl mx-auto">
      <div class="brik-hero-glow absolute inset-0 top-0 left-0 right-0 h-[60vh] pointer-events-none z-0 rounded-3xl blur-3xl"></div>
      
      <!-- Canvas Typography Particle Container -->
      <div class="relative w-full max-w-4xl h-[160px] sm:h-[220px] md:h-[260px] bg-black/[0.02] dark:bg-white/[0.01] border border-black/5 dark:border-white/5 rounded-3xl overflow-hidden cursor-crosshair z-25 shadow-inner-sm">
        <canvas id="hero-particle-canvas" class="absolute inset-0 w-full h-full touch-none"></canvas>
      </div>

      <div class="max-w-3xl mx-auto z-20 relative space-y-4 px-4">
        <h2 class="text-xl sm:text-3xl lg:text-4xl font-extrabold tracking-tight leading-snug text-transparent bg-clip-text bg-gradient-to-b from-text-main to-text-muted">
          Canvas Labs is an agentic platform designed to bring static graphics to life. 
          Describe your vision and deploy interactive tools that generate premium, customizable assets.
        </h2>
        <div class="pt-4 flex items-center justify-center gap-4">
          <a href={base + "/"} class="px-6 py-3 bg-brand-500 text-white rounded-2xl text-xs font-black uppercase tracking-wider hover:bg-brand-600 transition-colors shadow-sm cursor-pointer select-none">
            Enter Workspace Portal
          </a>
          <a href="#about-faq" class="px-6 py-3 bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10 border border-border-color text-text-main rounded-2xl text-xs font-bold transition-all select-none">
            Learn More
          </a>
        </div>
      </div>
    </section>

    <!-- Premium Interactive Unified Video Showcase Section -->
    <section class="space-y-8">
      <div class="flex flex-col gap-1.5 border-l-2 border-brand-500 pl-4">
        <h2 class="text-xs font-black text-text-main uppercase tracking-widest">Interactive Showroom</h2>
        <p class="text-[11px] text-text-muted font-medium font-mono">// preview our live vector instruments combined in one frame</p>
      </div>

      <div class="w-full bg-black/[0.015] dark:bg-white/[0.01] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 rounded-[36px] p-4 sm:p-6 lg:p-8 shadow-none relative overflow-hidden transition-all duration-500">
        
        <!-- Track Selector Tab Pills (Floats centered above player) -->
        <div class="flex border-b border-border-color/10 pb-4 mb-6 overflow-x-auto whitespace-nowrap gap-3 scrollbar-none justify-start lg:justify-center">
          <button
            data-video-src={`${base}/previews/typography/sam-hogan-drop.webm`}
            data-title="Finesse Kerning / Sam Hogan"
            data-desc="High-fidelity spring-loaded typography engine mimicking professional character drops, responsive space kerning, and smooth physics bounces."
            class="showcase-tab px-5 py-2.5 rounded-full text-[10px] font-black uppercase tracking-widest transition-all cursor-pointer bg-brand-500 text-white shadow-md"
          >
            Finesse Typography
          </button>
          
          <button
            data-video-src={`${base}/previews/typography/ransom-collage.webm`}
            data-title="Ransom Stop-Motion"
            data-desc="Edgy collage monogram editor displaying stop-motion paper clippings, raw text-transform offsets, and custom dynamic shadow parameters."
            class="showcase-tab px-5 py-2.5 rounded-full text-[10px] font-black uppercase tracking-widest transition-all cursor-pointer bg-black/5 dark:bg-white/5 text-text-muted hover:text-text-main"
          >
            Ransom Collage
          </button>

          <button
            data-video-src={`${base}/previews/typography/fireship-throw.webm`}
            data-title="Kinetic Throw / Fireship"
            data-desc="Hyper-fast throw animation featuring modular letter rotations, adjustable character sizes, and dynamic canvas backdrop wiggles."
            class="showcase-tab px-5 py-2.5 rounded-full text-[10px] font-black uppercase tracking-widest transition-all cursor-pointer bg-black/5 dark:bg-white/5 text-text-muted hover:text-text-main"
          >
            Kinetic Throw
          </button>

          <button
            data-video-src={`${base}/previews/charts/energy.webm`}
            data-title="Energy Flow / Klimt"
            data-desc="Translucent stream graphs and flow charts tracking network outputs. Features interactive wave playheads and custom color palettes."
            class="showcase-tab px-5 py-2.5 rounded-full text-[10px] font-black uppercase tracking-widest transition-all cursor-pointer bg-black/5 dark:bg-white/5 text-text-muted hover:text-text-main"
          >
            Energy Flow
          </button>

          <button
            data-video-src={`${base}/previews/charts/social.webm`}
            data-title="Social Growth Waves"
            data-desc="Modern graphical bar charts with smooth wave growth animations. Configured for client-side multi-aspect ratio rendering."
            class="showcase-tab px-5 py-2.5 rounded-full text-[10px] font-black uppercase tracking-widest transition-all cursor-pointer bg-black/5 dark:bg-white/5 text-text-muted hover:text-text-main"
          >
            Social Growth
          </button>
        </div>

        <!-- Grand Video Player Frame -->
        <div class="grid lg:grid-cols-12 gap-8 items-stretch">
          
          <!-- Unified HTML5 Player Screen (Spans 8 cols) -->
          <div class="lg:col-span-8 bg-[#f5f5f5] dark:bg-zinc-950 border border-slate-200/50 dark:border-zinc-800/60 rounded-[28px] overflow-hidden aspect-[4/3] sm:aspect-[16/9] relative group shadow-sm flex items-center justify-center">
            <video
              id="showcase-main-video"
              src={`${base}/previews/typography/sam-hogan-drop.webm`}
              autoplay
              loop
              muted
              playsinline
              class="w-full h-full object-cover z-0 pointer-events-none select-none transition-all duration-300"
            ></video>

            <!-- Custom Floating Glass Play Controls Overlay (visible on hover) -->
            <div class="absolute bottom-4 left-4 right-4 bg-white/90 dark:bg-zinc-900/90 backdrop-blur-xl border border-slate-200/50 dark:border-zinc-800/80 px-4 py-2 rounded-2xl flex items-center justify-between shadow-xl z-10 transition-opacity duration-300 pointer-events-auto select-none">
              <!-- Play/Pause Toggle -->
              <button id="btn-play-pause" class="p-2 hover:bg-black/10 dark:hover:bg-white/10 text-text-main hover:text-brand-500 rounded-lg transition-colors cursor-pointer flex items-center justify-center shrink-0">
                <!-- Play Icon -->
                <svg id="icon-play" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                <!-- Pause Icon -->
                <svg id="icon-pause" class="w-4 h-4 text-brand-500" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
              </button>
              
              <!-- Fullscreen Toggle -->
              <button id="btn-fullscreen" class="p-2 hover:bg-black/10 dark:hover:bg-white/10 text-text-main hover:text-brand-500 rounded-lg transition-colors cursor-pointer flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-brand-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Video Metadata & Desc (Spans 4 cols) -->
          <div class="lg:col-span-4 flex flex-col justify-between py-2.5 space-y-6">
            <div class="space-y-4">
              <span class="text-[9px] font-black uppercase tracking-widest text-brand-500 bg-brand-500/10 border border-brand-500/10 px-2.5 py-1 rounded-md">
                ACTIVE SHOWROOM INSTRUMENT
              </span>
              <h3 id="active-video-title" class="text-2xl font-black text-text-main leading-tight tracking-tight">
                Finesse Kerning / Sam Hogan
              </h3>
              <p id="active-video-desc" class="text-xs sm:text-sm text-text-muted leading-relaxed font-medium">
                High-fidelity spring-loaded typography engine mimicking professional character drops, responsive space kerning, and smooth physics bounces.
              </p>
            </div>

            <!-- PR/Workspace redirection options inside metadata column -->
            <div class="space-y-3 pt-6 border-t border-border-color/10">
              <p class="text-[10px] font-bold text-text-muted uppercase tracking-wider select-none">// launch the canvas editor</p>
              <a
                href={base + "/"}
                class="w-full inline-flex items-center justify-between px-5 py-3.5 bg-white dark:bg-zinc-900 border border-border-color dark:border-zinc-805 hover:border-brand-500/40 rounded-2xl text-xs font-bold text-text-main shadow-sm transition-all"
              >
                <span>Deploy Inside Sandbox</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mosaic Creative Card Grid -->
    <section class="space-y-8">
      <div class="flex flex-col gap-1.5 border-l-2 border-brand-500 pl-4">
        <h2 class="text-xs font-black text-text-main uppercase tracking-widest">Workspace Capabilities</h2>
        <p class="text-[11px] text-text-muted font-medium font-mono">// scale creative vision with dynamic variables</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 pt-2">
        <!-- Card 1 -->
        <div class="group bg-black/[0.01] dark:bg-white/[0.005] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 rounded-3xl p-6 flex flex-col justify-between min-h-[220px] transition-all hover:bg-black/[0.015] dark:hover:bg-white/[0.01]">
          <div class="space-y-3">
            <div class="w-10 h-10 rounded-xl bg-brand-500/10 text-brand-500 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7v2.5M4 7l2-1M4 7l2 1M6 9v2.5M6 9l6 3 6-3" /></svg>
            </div>
            <h3 class="text-sm font-black text-text-main uppercase tracking-wider">Dynamic Layout Specs</h3>
            <p class="text-xs text-text-muted leading-relaxed font-medium">
              Create responsive containers featuring custom scaling aspect-ratios, high-precision coordinates alignment, and real-time element transformations.
            </p>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="group bg-black/[0.01] dark:bg-white/[0.005] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 rounded-3xl p-6 flex flex-col justify-between min-h-[220px] transition-all hover:bg-black/[0.015] dark:hover:bg-white/[0.01]">
          <div class="space-y-3">
            <div class="w-10 h-10 rounded-xl bg-brand-500/10 text-brand-500 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg>
            </div>
            <h3 class="text-sm font-black text-text-main uppercase tracking-wider">Interactive Waveforms</h3>
            <p class="text-xs text-text-muted leading-relaxed font-medium">
              Standard sound structures configured to animate design layouts instantly. Sync custom playheads, durations, and wiggles with zero lagging.
            </p>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="group bg-black/[0.01] dark:bg-white/[0.005] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 rounded-3xl p-6 flex flex-col justify-between min-h-[220px] transition-all hover:bg-black/[0.015] dark:hover:bg-white/[0.01]">
          <div class="space-y-3">
            <div class="w-10 h-10 rounded-xl bg-brand-500/10 text-brand-500 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v1m6 11h2m-6 0h-2v4m0-16v4m0 4h.01M4 12h2m0 0h2v-4m0 8h.01M16 16h.01M12 12h.01M8 16h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            </div>
            <h3 class="text-sm font-black text-text-main uppercase tracking-wider">Vector Canvas Exports</h3>
            <p class="text-xs text-text-muted leading-relaxed font-medium">
              Render and export 4K PNG blueprints, clean SVG monograms, and high-quality loopable WebM creative videos directly to local storage.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section id="about-faq" class="space-y-8 pt-8">
      <div class="flex flex-col gap-1.5 border-l-2 border-brand-500 pl-4">
        <h2 class="text-xs font-black text-text-main uppercase tracking-widest">Frequently Asked Questions</h2>
        <p class="text-[11px] text-text-muted font-medium">Understand the logic behind Canvas Labs Studio</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start pt-2">
        <!-- Accordion Columns -->
        <div class="lg:col-span-3 space-y-4">
          <!-- Accordion Item 1 -->
          <div class="faq-accordion-item bg-black/[0.01] dark:bg-white/[0.005] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 rounded-2xl overflow-hidden active">
            <button class="w-full px-6 py-5 text-left font-black text-xs text-text-main uppercase tracking-wider flex justify-between items-center outline-none cursor-pointer">
              What is Canvas Labs?
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-text-muted transition-transform duration-300 faq-chevron rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-accordion-content max-h-[300px] transition-all duration-300 overflow-hidden px-6 pb-6 text-xs text-text-muted leading-relaxed font-medium space-y-2">
              <p>Canvas Labs is an interactive, agency-grade graphics sandbox designed to turn design templates into live vector utilities.</p>
              <p>By using direct visual controls, designers can easily edit text strings, wiggles, characters spacing, background themes, and offset drop shadows instantly.</p>
            </div>
          </div>

          <!-- Accordion Item 2 -->
          <div class="faq-accordion-item bg-black/[0.01] dark:bg-white/[0.005] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 rounded-2xl overflow-hidden">
            <button class="w-full px-6 py-5 text-left font-black text-xs text-text-main uppercase tracking-wider flex justify-between items-center outline-none cursor-pointer">
              Who is this studio designed for?
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-text-muted transition-transform duration-300 faq-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-accordion-content max-h-0 transition-all duration-300 overflow-hidden px-6 text-xs text-text-muted leading-relaxed font-medium space-y-2">
              <p>This workspace is built for marketers, product managers, media designers, and developers who seek standardized, rapid-prototyping platforms for generating production assets in seconds.</p>
            </div>
          </div>

          <!-- Accordion Item 3 -->
          <div class="faq-accordion-item bg-black/[0.01] dark:bg-white/[0.005] border border-black/5 dark:border-white/5 dark:border-zinc-800/40 rounded-2xl overflow-hidden">
            <button class="w-full px-6 py-5 text-left font-black text-xs text-text-main uppercase tracking-wider flex justify-between items-center outline-none cursor-pointer">
              Do I need coding experience?
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-text-muted transition-transform duration-300 faq-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-accordion-content max-h-0 transition-all duration-300 overflow-hidden px-6 text-xs text-text-muted leading-relaxed font-medium space-y-2">
              <p>Absolutely not. All advanced HTML5 canvas manipulations, spring-physics mathematical models, and rendering pipelines are loaded entirely under the hood. You only interact with premium typography preset cards, sliders, and colorways.</p>
            </div>
          </div>
        </div>

        <!-- High-contrast CTA Block -->
        <div class="lg:col-span-2">
          <div class="bg-gradient-to-br from-brand-600 via-pink-600 to-amber-500 rounded-3xl p-8 text-white shadow-xl lg:sticky lg:top-24 space-y-4">
            <span class="text-[9px] font-black uppercase tracking-widest bg-white/20 border border-white/10 px-2.5 py-1 rounded">Got Creative Vision?</span>
            <h3 class="text-2xl font-black leading-tight tracking-tight">
              Visit our <a href={base + "/press"} class="underline decoration-2 underline-offset-4 hover:text-pink-100 transition-colors">Press Kit</a> to download brand resources, or enter the <a href={base + "/"} class="underline decoration-2 underline-offset-4 hover:text-pink-100 transition-colors">Workspace</a> directly.
            </h3>
          </div>
        </div>
      </div>
    </section>

  </div>

  <!-- Marquee Style definitions & Brik Overrides -->
  <style is:global>
    /* Brik-style Global Overrides */
    body, html {
      background-color: #f2f2f2 !important;
      color: #111111 !important;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif !important;
    }
    
    .dark body, .dark html {
      background-color: #0c0c0c !important;
      color: #f3f3f3 !important;
    }

    ::selection {
      background-color: #f472b6 !important; /* hot pink selection bg */
      color: #000000 !important;
    }

    /* Override brand accents with Brik Hot Pink */
    .bg-brand-500 {
      background-color: #ff69b4 !important; /* Hot Pink */
    }
    .text-brand-500 {
      color: #ff69b4 !important;
    }
    .border-brand-500 {
      border-color: #ff69b4 !important;
    }
    
    .bg-brand-500\/10 {
      background-color: rgba(255, 105, 180, 0.1) !important;
    }
    
    .border-brand-500\/20 {
      border-color: rgba(255, 105, 180, 0.2) !important;
    }

    /* Radial rose hot pink glow behind Hero */
    .brik-hero-glow {
      background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(255, 105, 180, 0.4) 0%, rgba(242, 242, 242, 0) 100%) !important;
    }
    
    .dark .brik-hero-glow {
      background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(255, 105, 180, 0.18) 0%, rgba(12, 12, 12, 0) 100%) !important;
    }

    .marquee-container {
      display: flex;
      white-space: nowrap;
      overflow: hidden;
    }
    .marquee-content {
      display: flex;
    }
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .animate-marquee {
      animation: marquee 25s linear infinite;
    }
    
    /* Active FAQ state */
    .faq-accordion-item.active .faq-accordion-content {
      padding-bottom: 1.5rem;
    }
  </style>

  <!-- Interactive Particle canvas code -->
  <script is:inline>
    (function() {
      // Unified Showcase Video Player Interactivity
      const videoEl = document.getElementById('showcase-main-video');
      const tabs = document.querySelectorAll('.showcase-tab');
      const playPauseBtn = document.getElementById('btn-play-pause');
      const fullscreenBtn = document.getElementById('btn-fullscreen');
      const playIcon = document.getElementById('icon-play');
      const pauseIcon = document.getElementById('icon-pause');
      const titleDisplay = document.getElementById('active-video-title');
      const descDisplay = document.getElementById('active-video-desc');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          // Reset tabs styling
          tabs.forEach(t => {
            t.classList.remove('bg-brand-500', 'text-white', 'shadow-md', 'font-black');
            t.classList.add('bg-black/5', 'dark:bg-white/5', 'text-text-muted', 'hover:text-text-main');
          });

          // Set active tab styling
          tab.classList.remove('bg-black/5', 'dark:bg-white/5', 'text-text-muted', 'hover:text-text-main');
          tab.classList.add('bg-brand-500', 'text-white', 'shadow-md', 'font-black');

          // Retrieve metadata
          const videoSrc = tab.getAttribute('data-video-src');
          const title = tab.getAttribute('data-title');
          const desc = tab.getAttribute('data-desc');

          if (videoEl) {
            videoEl.src = videoSrc;
            videoEl.load();
            videoEl.play().catch(() => {});
          }

          if (titleDisplay) titleDisplay.textContent = title;
          if (descDisplay) descDisplay.textContent = desc;

          // Toggle icon states to playing
          if (playIcon) playIcon.classList.add('hidden');
          if (pauseIcon) pauseIcon.classList.remove('hidden');
        });
      });

      if (videoEl) {
        // Play / Pause Toggle click handler
        playPauseBtn?.addEventListener('click', () => {
          if (videoEl.paused) {
            videoEl.play();
            playIcon?.classList.add('hidden');
            pauseIcon?.classList.remove('hidden');
          } else {
            videoEl.pause();
            playIcon?.classList.remove('hidden');
            pauseIcon?.classList.add('hidden');
          }
        });

        // Fullscreen click handler
        fullscreenBtn?.addEventListener('click', () => {
          if (videoEl.requestFullscreen) {
            videoEl.requestFullscreen();
          } else if (videoEl.webkitRequestFullscreen) {
            videoEl.webkitRequestFullscreen();
          } else if (videoEl.msRequestFullscreen) {
            videoEl.msRequestFullscreen();
          }
        });
      }

      // FAQ Accordion Interactivity
      const items = document.querySelectorAll('.faq-accordion-item');
      items.forEach(item => {
        const btn = item.querySelector('button');
        const content = item.querySelector('.faq-accordion-content');
        const chevron = item.querySelector('.faq-chevron');

        btn.addEventListener('click', () => {
          const isActive = item.classList.contains('active');
          
          // Reset all
          items.forEach(el => {
            el.classList.remove('active');
            const c = el.querySelector('.faq-accordion-content');
            const ch = el.querySelector('.faq-chevron');
            c.style.maxHeight = '0';
            c.style.paddingBottom = '0';
            ch.classList.remove('rotate-180');
          });

          if (!isActive) {
            item.classList.add('active');
            content.style.maxHeight = '300px';
            content.style.paddingBottom = '1.5rem';
            chevron.classList.add('rotate-180');
          }
        });
      });

      // Canvas Interactive Particle Typography Engine
      const canvas = document.getElementById('hero-particle-canvas');
      const ctx = canvas.getContext('2d', { willReadFrequently: true });
      
      let particles = [];
      let mouse = { x: -1000, y: -1000, radius: 100 };
      const TEXT = "Canvas Labs";

      class Particle {
        constructor(x, y, color) {
          this.x = Math.random() * canvas.width;
          this.y = Math.random() * canvas.height;
          this.baseX = x;
          this.baseY = y;
          this.color = color;
          this.size = Math.random() * 2 + 1.5;
          this.vx = 0;
          this.vy = 0;
          this.friction = 0.85;
          this.springFactor = 0.06;
        }

        update() {
          const dx = mouse.x - this.x;
          const dy = mouse.y - this.y;
          const distance = Math.sqrt(dx * dx + dy * dy);

          if (distance < mouse.radius) {
            const forceDirectionX = dx / distance;
            const forceDirectionY = dy / distance;
            const force = (mouse.radius - distance) / mouse.radius;
            const directionX = forceDirectionX * force * -6;
            const directionY = forceDirectionY * force * -6;

            this.vx += directionX;
            this.vy += directionY;
          }

          this.vx += (this.baseX - this.x) * this.springFactor;
          this.vy += (this.baseY - this.y) * this.springFactor;
          this.vx *= this.friction;
          this.vy *= this.friction;

          this.x += this.vx;
          this.y += this.vy;
        }

        draw() {
          ctx.fillStyle = this.color;
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      function initParticles() {
        particles = [];
        const rect = canvas.parentElement.getBoundingClientRect();
        
        if (rect.width === 0 || rect.height === 0) {
          setTimeout(initParticles, 100);
          return;
        }

        canvas.width = rect.width;
        canvas.height = rect.height;

        const targetWidth = canvas.width * 0.85;
        const maxFontSize = 140;
        
        ctx.font = '900 80px "Outfit", "Inter", sans-serif';
        const baseMetrics = ctx.measureText(TEXT);
        const scaleFactor = targetWidth / baseMetrics.width;
        const fontSize = Math.min(maxFontSize, 80 * scaleFactor);

        ctx.font = `900 ${fontSize}px "Outfit", "Inter", sans-serif`;
        const metrics = ctx.measureText(TEXT);
        const textWidth = metrics.width;
        const xOffset = (canvas.width - textWidth) / 2;
        const yOffset = (canvas.height + fontSize * 0.7) / 2;

        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = 'white';
        ctx.fillText(TEXT, xOffset, yOffset);

        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const data = imageData.data;
        const step = Math.floor(Math.max(4, canvas.width / 180));

        const colorStart = { r: 124, g: 58, b: 237 }; // Purple (brand brand-600)
        const colorEnd = { r: 236, g: 72, b: 153 };   // Pink

        ctx.clearRect(0, 0, canvas.width, canvas.height);

        for (let y = 0; y < canvas.height; y += step) {
          for (let x = 0; x < canvas.width; x += step) {
            const index = (y * canvas.width + x) * 4;
            if (data[index + 3] > 128) {
              const jx = x + (Math.random() - 0.5) * step;
              const jy = y + (Math.random() - 0.5) * step;
              const factor = Math.max(0, Math.min(1, (x - xOffset) / textWidth));
              const r = Math.round(colorStart.r + factor * (colorEnd.r - colorStart.r));
              const g = Math.round(colorStart.g + factor * (colorEnd.g - colorStart.g));
              const b = Math.round(colorStart.b + factor * (colorEnd.b - colorStart.b));
              const finalColor = `rgb(${r}, ${g}, ${b})`;
              particles.push(new Particle(jx, jy, finalColor));
            }
          }
        }
      }

      function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (let i = 0; i < particles.length; i++) {
          particles[i].update();
          particles[i].draw();
        }
        requestAnimationFrame(animate);
      }

      canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
      });

      canvas.addEventListener('mouseleave', () => {
        mouse.x = -1000;
        mouse.y = -1000;
      });

      canvas.addEventListener('touchmove', (e) => {
        e.preventDefault();
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.touches[0].clientX - rect.left;
        mouse.y = e.touches[0].clientY - rect.top;
      }, { passive: false });

      canvas.addEventListener('touchend', () => {
        mouse.x = -1000;
        mouse.y = -1000;
      });

      window.addEventListener('resize', () => {
        clearTimeout(window.particleTimeout);
        window.particleTimeout = setTimeout(initParticles, 200);
      });

      document.fonts.ready.then(() => {
        initParticles();
        animate();
      });
    })();
  </script>
</Layout>
