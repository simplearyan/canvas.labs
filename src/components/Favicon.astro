---
import { SITE_CONFIG } from '../config/site';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL;
const lightSvg = base + SITE_CONFIG.tabPreferences.favicon.lightTabSvg;
const darkSvg = base + SITE_CONFIG.tabPreferences.favicon.darkTabSvg;
const defaultFav = base + SITE_CONFIG.tabPreferences.favicon.default;
---

{/* 1. Cross-platform & Social Launcher Fallbacks (Parsed first) */}
<link rel="manifest" href={`${base}/site.webmanifest`} />
<link rel="apple-touch-icon" sizes="180x180" href={`${base}/apple-touch-icon.png`} />
<link rel="icon" type="image/png" sizes="512x512" href={`${base}/android-chrome-512x512.png`} />
<link rel="icon" type="image/png" sizes="192x192" href={`${base}/android-chrome-192x192.png`} />
<link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon-32x32.png`} />
<link rel="icon" type="image/png" sizes="16x16" href={`${base}/favicon-16x16.png`} />
<link rel="shortcut icon" href={`${base}/favicon.ico`} />

{/* 2. Dynamic, High-Specificity Favicon Tags (Parsed last to override fallbacks) */}
{SITE_CONFIG.tabPreferences.favicon.useSvgIcon ? (
	<>
		<link rel="icon" type="image/svg+xml" href={lightSvg} sizes="any" media="(prefers-color-scheme: light)" />
		<link rel="icon" type="image/svg+xml" href={darkSvg} sizes="any" media="(prefers-color-scheme: dark)" />
	</>
) : (
	<>
		<link rel="icon" href={`data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><text y=".9em" font-size="90">${SITE_CONFIG.tabPreferences.favicon.lightTabEmoji}</text></svg>`} media="(prefers-color-scheme: light)" />
		<link rel="icon" href={`data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><text y=".9em" font-size="90">${SITE_CONFIG.tabPreferences.favicon.darkTabEmoji}</text></svg>`} media="(prefers-color-scheme: dark)" />
	</>
)}
